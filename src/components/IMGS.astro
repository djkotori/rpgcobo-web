---
import type { ImageMetadata } from 'astro';
import { Image, getImage } from 'astro:assets';

//	/src/assets/以下のパスを指定する。
//	enとかで置き換え可能

interface Props {
	srcs: Array<string>;
}

const { srcs } = Astro.props;

const slug = Astro.params.slug;
const lang = slug ? (slug.indexOf( "/")>=0 ? slug.slice( 0, slug.indexOf( "/")) : slug) : null;
const cdir = process.cwd();

const a = [];
for( let i in srcs){
   let src = srcs[i];
   let imgpath = "/src/assets/" + src;
   const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/**/*.{jpeg,jpg,png,gif,webp}');
   let imgref = images[imgpath];
   if( !imgref) {
      console.log( images);
      throw new Error(`"${imgpath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif}"`);
   }
   console.log( imgref);
   a.push( imgref());
}

let fade = 1000;
let delay = 4000;
let dur = (delay+fade) * a.length;
//  t1 = fade / dur
//  t2 = (delay+fade) / dur
//  t3 = 1.0 - fade / dur
//  n=2 dur=10000   t1=40% t2=50% t3=60%
//  n=3 dur=15000   t1=7% t2=33% t3=40%

let kf = `animation: fade${a.length} ${dur}ms linear infinite;`;

---
<div class="images">
  {a.map((src, i) => (
    <Image src={src} alt="img" class="img" style={`--i:${i}; ${kf}; animation-delay: ${i*(fade+delay)}ms;`} />
  ))}
</div>

<style>
.images {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.images .img {
  position: absolute;
  inset: 0;
  padding: 0;
  margin: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;

  opacity: 0;
}

@keyframes fade1 {
  0% { opacity: 1 }
  100% { opacity: 1 }
}
@keyframes fade2 {
  0% { opacity: 0 }
  10% { opacity: 1 }
  50% { opacity: 1 }
  60% { opacity: 0 }
  100% { opacity: 0 }
}
@keyframes fade3 {
  0% { opacity: 0 }
  7% { opacity: 1 }
  33% { opacity: 1 }
  40% { opacity: 0 }
  100% { opacity: 0 }
}
@keyframes fade4 {
  0% { opacity: 0 }
  5% { opacity: 1 }
  25% { opacity: 1 }
  30% { opacity: 0 }
  100% { opacity: 0 }
}
</style>
