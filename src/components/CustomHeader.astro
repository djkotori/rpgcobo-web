---
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
import options from 'virtual:starlight-theme-nova/user-config'

const nav = options.nav ?? []

const route = Astro.locals.starlightRoute

function trans( item, route){
	const { lang, locale } = route;
	// console.log( item, lang, locale);
	return item.translations?.[lang] || item.label;
}

---

<div class="nova-header">
  <div class="nova-header-title">
    <SiteTitle />
  </div>
  <nav class="nova-header-nav">
    {
      nav.map((item) => (
        <a class="nova-header-nav-link" href={ item.href}>
          { trans( item, route) }
        </a>
      ))
    }
  </nav>
  <div class="nova-header-search">
    <Search />
  </div>
  <div class="nova-header-actions-lg">
    <SocialIcons />
    <LanguageSelect />
    <ThemeSelect />
  </div>



  <input type="checkbox" name="hamburger" id="hamburger" class="c-hamburger-menu__input"/>
  <label for="hamburger" class="c-hamburger-menu__bg"></label>
  <ul class="c-header__list c-hamburger-menu__list">
    {
      nav.map((item) => (
		<li class="c-header__list-item">
			<a href={item.href} class="c-header__list-link">{ trans( item, route) }</a>
		</li>
      ))
    }
  </ul>
  <label for="hamburger" class="c-hamburger-menu__button">
    <span class="c-hamburger-menu__button-mark"></span>
    <span class="c-hamburger-menu__button-mark"></span>
    <span class="c-hamburger-menu__button-mark"></span>
  </label>

</div>
