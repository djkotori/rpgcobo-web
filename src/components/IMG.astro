---
import type { ImageMetadata } from 'astro';
import { Image, getImage } from 'astro:assets';

//	/src/assets/以下のパスを指定する。
//	enとかで置き換え可能

interface Props {
   src: string;
   alt: string;
   minscale: number;
}

const { src, alt, minscale } = Astro.props;

const slug = Astro.params.slug;
const lang = slug ? (slug.indexOf( "/")>=0 ? slug.slice( 0, slug.indexOf( "/")) : slug) : null;
let imgpath = "/src/assets/" + src;

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/**/*.{jpeg,jpg,png,gif,webp,svg}');
let imgref = images[imgpath];
if( !imgref) {
	console.log( images);
	throw new Error(`"${imgpath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,webp,svg}"`);
}

const cdir = process.cwd();

let img = imgref();
---
<Image src={img} alt={alt}/>